source "https://rubygems.org"

# Use native Jekyll 4.x to avoid Ruby 3.2 compatibility issues with
# github-pages (Jekyll 3.9 / Liquid 4.0.3).
gem "jekyll", "~> 4.3"

gem "wdm", "~> 0.1.0" if Gem.win_platform?

# If you have any plugins, put them here!
group :jekyll_plugins do
  gem "jekyll-feed"
  gem 'jekyll-sitemap'
  gem 'jekyll-seo-tag'
  gem 'jekyll-redirect-from'
  gem 'jekyll-paginate'
  gem 'jekyll-gist'
end
